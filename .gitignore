# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Testing
coverage/

# Next.js
.next/
out/
build/
dist/

# PWA build artifacts (generated by next build via @ducanh2912/next-pwa)
public/sw.js
public/workbox-*.js
public/fallback-*.js
public/worker-*.js

# Production
*.tsbuildinfo
next-env.d.ts

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local env files
.env
.env*.local
.env.development
.env.production

# Vercel
.vercel

# IDE
.idea/
*.swp
*.swo
.vscode/
!.vscode/extensions.json

# Claude Code per-developer artifacts. settings.json carried allow/deny
# permission lists that drift per machine; tracking it caused merge churn,
# so we treat it the same as settings.local.json now.
.claude/settings.json
.claude/settings.local.json

# Tokyo Met open-data CSVs cached by scripts/generate-pois.ts.
# Tokyo-wide files (避難所 ~13MB) are too large for git; the script refetches
# from the upstream CKAN-resolved URL on demand, then filters down to Koto-ku.
__fixtures__/opendata/tokyo-*.csv

# Everything under data/ is treated as a generated artefact by default —
# either served live via /api/datasets/* or produced by ensure-data at
# predev/prebuild/pretest. Curated files (gomi-dictionary.json,
# gomi-schedule.json) are the explicit exceptions; any new dataset added
# in the future is ignored automatically unless added to the allowlist
# below.
data/*
!data/gomi-dictionary.json
!data/gomi-schedule.json

# PID + log for `scripts/dev.sh` (detached `npm run dev`).
.run/
